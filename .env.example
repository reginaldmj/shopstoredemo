# Environment variable sample for the backend server.
# Copy this file to .env and update values before running locally or in production.

# MongoDB connection string
# Local example:
# MONGO_URI=mongodb://127.0.0.1:27017/mono-store
# Atlas example:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mono-store?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/mono-store

# Allowed CORS origin(s) for the API.
# Single origin example:
# CORS_ORIGIN=https://your-store.netlify.app
# Multiple origins example (comma-separated):
# CORS_ORIGIN=https://your-store.netlify.app,https://www.yourdomain.com
CORS_ORIGIN=http://127.0.0.1:5173
